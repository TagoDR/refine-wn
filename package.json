{
  "name": "refine-wn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prettier": "prettier --write \"**/*.{md,html,svg}\" \"!dist/**\" \"!node_modules/**\" \"!*.user.js\"",
    "biome": "biome check --fix ."
  },
  "devDependencies": {
    "@awesome.me/webawesome": "^3.5.0",
    "@biomejs/biome": "^2.4.13",
    "@types/jszip": "^3.4.0",
    "idb-keyval": "^6.2.2",
    "lit": "^3.3.2",
    "nanostores": "^1.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.svg",
        "options": {
          "parser": "html"
        }
      }
    ],
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "arrowParens": "avoid",
    "endOfLine": "crlf",
    "singleAttributePerLine": true
  }
}
